@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Routing



<!-- TopNavBar -->
<header class="fixed top-0 w-full z-50 bg-slate-50/80 dark:bg-slate-950/80 backdrop-blur-xl shadow-sm shadow-blue-900/5 no-border-tonal-shift">
<div class="flex justify-between items-center px-6 py-4 max-w-7xl mx-auto">
<div class="font-headline font-extrabold text-blue-700 dark:text-blue-500 tracking-tight text-xl">بنك المبرمجين</div>
<div class="flex items-center space-x-reverse space-x-4">
<div class="flex items-center space-x-reverse space-x-2 ml-4">
<button class="p-2 text-slate-500 hover:text-blue-600 transition-colors">
<span class="material-symbols-outlined" data-icon="notifications">notifications</span>
</button>
<button class="p-2 text-slate-500 hover:text-blue-600 transition-colors">
<span class="material-symbols-outlined" data-icon="help_outline">help_outline</span>
</button>
</div>
<img alt="User profile photo" class="w-10 h-10 rounded-full border-2 border-surface-container-high object-cover" data-alt="Professional headshot of a middle-aged executive man with a kind smile, clean corporate background, soft studio lighting" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAhznnWAFMC3ozq9GHnvs4-WuK1EwMP4eATSnUYfkykqNbAx8FYsOJs3sEskFr5RvzuLdKDUDEEKHiX5kKAejCm0JHbUoLBzHHjB3ukrUL5PtDB-Zgi58e1hn8J7wG5WvSu29GyL49ampVcjIVhORqem4c4QXMrxgDLHu6lty6O2IxC6XtbjLQAdTF027EOQQuO-sHAc6NS_9aL-cZJmBNIiU2m9W5csMNdUgL9or-BE7z3wrobP6dW8Uij992clCq4qYnWBbOrYVc"/>
</div>
</div>
</header>

<!-- SideNavBar (Desktop Only) -->
<aside>
    <div class="mb-8 px-4 py-6">
            <div class="text-xl font-bold text-blue-700 mb-1">الخدمات المصرفية الخاصة</div>
    </div>
    <nav class="space-y-1">
        <NavLink class="sidebar-link flex items-center space-x-reverse space-x-3 px-4 py-3 rounded-xl font-headline text-sm font-semibold transition-all active:-translate-x-1 duration-150" href="/dashboard" Match="NavLinkMatch.All">
            <span class="material-symbols-outlined" data-icon="dashboard">dashboard</span>
            <span>لوحة التحكم</span>
        </NavLink>
        <NavLink class="sidebar-link flex items-center space-x-reverse space-x-3 px-4 py-3 rounded-xl font-headline text-sm font-semibold transition-all active:-translate-x-1 duration-150" href="/send" Match="NavLinkMatch.All">
            <span class="material-symbols-outlined" data-icon="send">send</span>
            <span>إرسال أموال</span>
        </NavLink>
        <NavLink class="sidebar-link flex items-center space-x-reverse space-x-3 px-4 py-3 rounded-xl font-headline text-sm font-semibold transition-all active:-translate-x-1 duration-150" href="/receive" Match="NavLinkMatch.All">
            <span class="material-symbols-outlined" data-icon="qr_code_2">qr_code_2</span>
            <span>استلام أموال</span>
        </NavLink>
        <NavLink class="sidebar-link flex items-center space-x-reverse space-x-3 px-4 py-3 rounded-xl font-headline text-sm font-semibold transition-all active:-translate-x-1 duration-150" href="/info" Match="NavLinkMatch.All">
            <span class="material-symbols-outlined" data-icon="person">person</span>
            <span>الملف الشخصي</span>
        </NavLink>
    </nav>
   
</aside>


<!-- BottomNavBar (Mobile Only) -->
<nav class="md:hidden fixed bottom-0 left-0 w-full z-50 bg-white/80 backdrop-blur-xl flex justify-around items-center px-4 pb-6 pt-3 shadow-[0_-10px_30px_rgba(0,0,0,0.04)] rounded-t-3xl">
<NavLink class="mobile-nav-link flex flex-col items-center justify-center p-2" href="/dashboard" Match="NavLinkMatch.All">
<span class="material-symbols-outlined">home</span>
<span class="font-inter text-[10px] font-medium tracking-wide">الرئيسية</span>
</NavLink>
<NavLink class="mobile-nav-link flex flex-col items-center justify-center p-2" href="/send" Match="NavLinkMatch.All">
<span class="material-symbols-outlined">payments</span>
<span class="font-inter text-[10px] font-medium tracking-wide">إرسال</span>
</NavLink>
<NavLink class="mobile-nav-link flex flex-col items-center justify-center p-2" href="/receive" Match="NavLinkMatch.All">
<span class="material-symbols-outlined">qr_code_scanner</span>
<span class="font-inter text-[10px] font-medium tracking-wide">استلام</span>
</NavLink>
<NavLink class="mobile-nav-link flex flex-col items-center justify-center p-2" href="/info" Match="NavLinkMatch.All">
<span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">account_circle</span>
<span class="font-inter text-[10px] font-medium tracking-wide">الملف الشخصي</span>
</NavLink>
</nav>

<!-- Main Content Canvas -->
<div class="Page">
@Body

</div>
<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>
